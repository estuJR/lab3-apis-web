{
	"info": {
		"_postman_id": "err-001",
		"name": "Errores Intencionales",
		"description": "Colección de requests que provocan errores HTTP conocidos en DummyJSON API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "404 Not Found - Producto inexistente",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{baseURL}}/{{resource}}/99999",
					"host": ["{{baseURL}}"],
					"path": ["{{resource}}", "99999"]
				}
			}
		},
		{
			"name": "404 Not Found - Ruta inexistente",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{baseURL}}/rutaquenoexiste",
					"host": ["{{baseURL}}"],
					"path": ["rutaquenoexiste"]
				}
			}
		},
		{
			"name": "400 Bad Request - Login sin credenciales",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{}"
				},
				"url": {
					"raw": "{{baseURL}}/auth/login",
					"host": ["{{baseURL}}"],
					"path": ["auth", "login"]
				}
			}
		},
		{
			"name": "400 Bad Request - Credenciales incorrectas",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"invaliduser\",\n  \"password\": \"wrongpassword\"\n}"
				},
				"url": {
					"raw": "{{baseURL}}/auth/login",
					"host": ["{{baseURL}}"],
					"path": ["auth", "login"]
				}
			}
		},
		{
			"name": "401 Unauthorized - Acceso sin token",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{baseURL}}/auth/products",
					"host": ["{{baseURL}}"],
					"path": ["auth", "products"]
				}
			}
		},
		{
			"name": "403 Forbidden - Token inválido/expirado",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer token_invalido_123456789"
					}
				],
				"url": {
					"raw": "{{baseURL}}/auth/products",
					"host": ["{{baseURL}}"],
					"path": ["auth", "products"]
				}
			}
		}
	]
}
