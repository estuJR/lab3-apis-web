{
	"info": {
		"_postman_id": "real-001",
		"name": "Solicitud Real",
		"description": "Flujo completo de una solicitud real: login, consultar productos con auth, y agregar producto al carrito",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login - Obtener token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.environment.set('token', jsonData.accessToken);",
							"pm.environment.set('refreshToken', jsonData.refreshToken);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\",\n  \"expiresInMins\": 30\n}"
				},
				"url": {
					"raw": "{{baseURL}}/auth/login",
					"host": ["{{baseURL}}"],
					"path": ["auth", "login"]
				}
			}
		},
		{
			"name": "2. Ver perfil autenticado",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseURL}}/auth/me",
					"host": ["{{baseURL}}"],
					"path": ["auth", "me"]
				}
			}
		},
		{
			"name": "3. Buscar productos autenticado",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseURL}}/auth/products/search?q=laptop",
					"host": ["{{baseURL}}"],
					"path": ["auth", "products", "search"],
					"query": [
						{
							"key": "q",
							"value": "laptop"
						}
					]
				}
			}
		},
		{
			"name": "4. Agregar producto al carrito",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userId\": 1,\n  \"products\": [\n    {\n      \"id\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"id\": 50,\n      \"quantity\": 1\n    }\n  ]\n}"
				},
				"url": {
					"raw": "{{baseURL}}/carts/add",
					"host": ["{{baseURL}}"],
					"path": ["carts", "add"]
				}
			}
		},
		{
			"name": "5. Ver carritos del usuario",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseURL}}/carts/user/1",
					"host": ["{{baseURL}}"],
					"path": ["carts", "user", "1"]
				}
			}
		}
	]
}
